# ── LLM provider selection ───────────────────────────────────────────
# bedrock (default) | claude | ollama | hybrid
LLM_PROVIDER=bedrock

# ── AWS Bedrock (Claude) ─────────────────────────────────────────────
# If running with IAM Role, the three lines below are not needed (auto auth)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-west-2

# Bedrock inference profile ID (required for latest models)
# List available: aws bedrock list-inference-profiles --region us-west-2
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# ── Anthropic Claude API (direct) ────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Ollama (local LLM) ───────────────────────────────────────────────
# Prerequisites:
#   1. Install Ollama from https://ollama.com
#   2. ollama serve
#   3. ollama pull gemma3:4b        (recommended from benchmark results)
#   4. ollama pull nomic-embed-text (embeddings)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Hybrid (local eval + cloud synthesis) ────────────────────────────
HYBRID_CLOUD_PROVIDER=bedrock
HYBRID_LOCAL_PROVIDER=ollama
HYBRID_LOCAL_MODEL=gemma3:4b

# ── Tavily web search ─────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
